<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
	version="6.0">

	<!-- ── Welcome file ────────────────────────── -->
	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
	</welcome-file-list>

	<!-- ── Auth Filter ──────────────────────────── -->
	<filter>
		<filter-name>AuthFilter</filter-name>
		<filter-class>com.eds.servlet.AuthFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>AuthFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<!-- ── Login ────────────────────────────────── -->
	<servlet>
		<servlet-name>LoginServlet</servlet-name>
		<servlet-class>com.eds.servlet.LoginServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LoginServlet</servlet-name>
		<url-pattern>/login</url-pattern>
	</servlet-mapping>

	<!-- ── Logout ───────────────────────────────── -->
	<servlet>
		<servlet-name>LogoutServlet</servlet-name>
		<servlet-class>com.eds.servlet.LogoutServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LogoutServlet</servlet-name>
		<url-pattern>/logout</url-pattern>
	</servlet-mapping>

	<!-- ── Dashboard ───────────────────────────── -->
	<servlet>
		<servlet-name>DashboardServlet</servlet-name>
		<servlet-class>com.eds.servlet.DashboardServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>DashboardServlet</servlet-name>
		<url-pattern>/dashboard</url-pattern>
	</servlet-mapping>

	<!-- ── View Employees ──────────────────────── -->
	<servlet>
		<servlet-name>ViewEmployeeServlet</servlet-name>
		<servlet-class>com.eds.servlet.ViewEmployeeServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ViewEmployeeServlet</servlet-name>
		<url-pattern>/employees</url-pattern>
	</servlet-mapping>

	<!-- ── Add Employee ────────────────────────── -->
	<servlet>
		<servlet-name>AddEmployeeServlet</servlet-name>
		<servlet-class>com.eds.servlet.AddEmployeeServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>AddEmployeeServlet</servlet-name>
		<url-pattern>/add</url-pattern>
	</servlet-mapping>

	<!-- ── Update Employee ─────────────────────── -->
	<servlet>
		<servlet-name>UpdateEmployeeServlet</servlet-name>
		<servlet-class>com.eds.servlet.UpdateEmployeeServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>UpdateEmployeeServlet</servlet-name>
		<url-pattern>/edit</url-pattern>
	</servlet-mapping>

	<!-- ── Delete Employee ─────────────────────── -->
	<servlet>
		<servlet-name>DeleteEmployeeServlet</servlet-name>
		<servlet-class>com.eds.servlet.DeleteEmployeeServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>DeleteEmployeeServlet</servlet-name>
		<url-pattern>/delete</url-pattern>
	</servlet-mapping>

	<!-- ── Profile ─────────────────────────────── -->
	<servlet>
		<servlet-name>ProfileServlet</servlet-name>
		<servlet-class>com.eds.servlet.ProfileServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ProfileServlet</servlet-name>
		<url-pattern>/profile</url-pattern>
	</servlet-mapping>

	<!-- ── Departments ─────────────────────────── -->
	<servlet>
		<servlet-name>DepartmentServlet</servlet-name>
		<servlet-class>com.eds.servlet.DepartmentServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>DepartmentServlet</servlet-name>
		<url-pattern>/departments</url-pattern>
	</servlet-mapping>

	<!-- ── Toggle Status ───────────────────────── -->
	<servlet>
		<servlet-name>ToggleStatusServlet</servlet-name>
		<servlet-class>com.eds.servlet.ToggleStatusServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ToggleStatusServlet</servlet-name>
		<url-pattern>/toggle-status</url-pattern>
	</servlet-mapping>

	<!-- ── Export CSV ──────────────────────────── -->
	<servlet>
		<servlet-name>ExportCSVServlet</servlet-name>
		<servlet-class>com.eds.servlet.ExportCSVServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ExportCSVServlet</servlet-name>
		<url-pattern>/export-csv</url-pattern>
	</servlet-mapping>

	<!-- ── Chart Data ──────────────────────────── -->
	<servlet>
		<servlet-name>ChartDataServlet</servlet-name>
		<servlet-class>com.eds.servlet.ChartDataServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ChartDataServlet</servlet-name>
		<url-pattern>/chart-data</url-pattern>
	</servlet-mapping>

	<!-- ── Session timeout 30 minutes ─────────── -->
	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>

	<!-- ── Error pages ─────────────────────────── -->
	<error-page>
		<error-code>404</error-code>
		<location>/error.jsp</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/error.jsp</location>
	</error-page>

	<!-- ── About ────────────────────────────────── -->
	<servlet>
		<servlet-name>AboutServlet</servlet-name>
		<servlet-class>com.eds.servlet.AboutServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>AboutServlet</servlet-name>
		<url-pattern>/about</url-pattern>
	</servlet-mapping>

</web-app>